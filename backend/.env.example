DATABASE_URL=sqlite+aiosqlite:///./dev.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/gymcoach

# Local dev without Firebase (never in production)
DEV_BYPASS_AUTH=true
DEV_FIREBASE_UID=dev-coach-uid
DEV_COACH_EMAIL=dev@example.com
DEV_COACH_NAME=Dev Coach

# Production: path to Firebase service account JSON
# FIREBASE_CREDENTIALS_PATH=/path/to/serviceAccount.json

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
