DATABASE_URL=sqlite+aiosqlite:///./dev.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/gymcoach

# Local dev without Firebase (never in production)
DEV_BYPASS_AUTH=true
DEV_FIREBASE_UID=dev-coach-uid
DEV_COACH_EMAIL=dev@example.com
DEV_COACH_NAME=Dev Coach

# Production: path to Firebase service account JSON
# FIREBASE_CREDENTIALS_PATH=/path/to/serviceAccount.json

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI workout draft (POST /api/v1/ai/training-plan-draft). OpenAI-compatible APIs supported (OpenAI, OpenRouter, etc.).
# OPENAI_API_KEY=
# Optional: https://openrouter.ai/api/v1
# OPENAI_BASE_URL=
# Cheap defaults: gpt-4.1-nano (default in code) or gpt-4o-mini. On OpenRouter use a slug, e.g. openai/gpt-4.1-nano-2025-04-14
# OPENAI_MODEL=gpt-4.1-nano

# Local media uploads (default: backend/uploads). Optional absolute URL prefix for public_url in API JSON.
# MEDIA_UPLOAD_DIR=uploads
# MEDIA_PUBLIC_BASE_URL=
# MEDIA_MAX_UPLOAD_BYTES=52428800
# MEDIA_MAX_ASSETS_PER_EXERCISE=24
