# Required on a real device or simulator: full origin of the FastAPI server (no trailing slash).
# iOS Simulator can use your machine: http://127.0.0.1:8000
# Android Emulator uses http://10.0.2.2:8000 instead of localhost.
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

# Match backend DEV_BYPASS_AUTH — use dummy Bearer token "dev" like the web dev login.
EXPO_PUBLIC_DEV_AUTH=true

# Production Firebase (same as frontend VITE_FIREBASE_*). Optional if you only use dev login.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
