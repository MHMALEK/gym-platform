# API (empty = same origin + Vite /api proxy)
VITE_API_URL=

# Dev: skip Firebase and use POST /auth/bootstrap with a dummy Bearer token
VITE_DEV_AUTH=true

# Firebase (production or local testing with real Auth). From Firebase console → Project settings → Web app.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
# Required for exercise media uploads to Firebase Storage (e.g. my-project.appspot.com)
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "false" to always use API disk upload (POST /media/upload) even if Storage is configured
# VITE_USE_FIREBASE_STORAGE=false
